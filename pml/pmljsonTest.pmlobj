define method .testParseArray(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !expected[1] = object DICTIONARY()
    !expected[1].SetValue('foo', 123)
    !expected[1].SetValue('bar', 456)
    !expected[1].SetValue('baz', 789)
    !expected[2] = Split('foo bar baz')
    !expected[3] = true
    !expected[4] = 123
    !expected[5] = 0.123
    !expected[6] = 'foo'
    !expected[7] = object STRING()
    !json = object PMLJSON()
    !actual = object ARRAY()
    !json.Parse('[{"foo":123,"bar":456,"baz":789},["foo","bar","baz"],true,123,0.123,"foo",null]', !actual)
    !assert.equal(!expected, !actual)
endmethod

define method .testParseArrayNull(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !actual = Split('foo')
    !assert.isSet(!actual)
    !json.Parse('null', !actual)
    !assert.isUnset(!actual)
endmethod

define method .testParseDictionary(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !dict = object DICTIONARY()
    !dict.SetValue('foo', 123)
    !dict.SetValue('bar', 456)
    !dict.SetValue('baz', 789)
    !expected = object DICTIONARY()
    !expected.SetValue('dictionary', !dict)
    !expected.SetValue('array', Split('foo bar baz'))
    !expected.SetValue('boolean', true)
    !expected.SetValue('integer', 123)
    !expected.SetValue('float', 0.123)
    !expected.SetValue('string', 'foo')
    !expected.SetValue('null', object STRING(), true)
    !json = object PMLJSON()
    !actual = object DICTIONARY()
    !json.Parse('{
    "dictionary": { "foo": 123, "bar": 456, "baz": 789 },
    "array": ["foo", "bar", "baz"],
    "boolean": true,
    "integer": 123,
    "float": 0.123,
    "string": "foo",
    "null": null
}', !actual)
    !assert.equal(!expected, !actual)
endmethod

define method .testParseDictionaryWithReplacing(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !actual = object DICTIONARY()
    !actual.SetValue('foo', 123)
    !actual.SetValue('bar', 456)
    !actual.SetValue('baz', 789)
    !json.Parse('{"bar":555}', !actual)
    !assert.equal(123, !actual.values[!actual.keys.FindFirst('foo')])
    !assert.equal(555, !actual.values[!actual.keys.FindFirst('bar')])
    !assert.equal(789, !actual.values[!actual.keys.FindFirst('baz')])
endmethod

define method .testParseDictionaryNull(!assert is PmlAssert)
