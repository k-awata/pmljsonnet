define object pmljsonTest
endobject

define method .testFileReadWrite(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !file = object FILE('%temp%\pmljsontest.json')
    !expected = object POSITION('N 123')
    !json = object PMLJSON()
    !json.WriteFile(!file, !expected)
    !actual = object POSITION('N 0')
    !assert.notEqual(!expected, !actual)
    !json.Parse(!file, !actual)
    !assert.equal(!expected, !actual)
endmethod

define method .testCreateNewObject(!assert is PmlAssert)
    using namespace 'PMLJsonNet'

    !json = object PMLJSON()

    !json.net.Parse('{}')
    !assert.instanceOf(!json.CreateNewObject(), 'DICTIONARY')

    !json.net.Parse('[]')
    !assert.instanceOf(!json.CreateNewObject(), 'ARRAY')

    !json.net.Parse('true')
    !assert.instanceOf(!json.CreateNewObject(), 'BOOLEAN')

    !json.net.Parse('123')
    !assert.instanceOf(!json.CreateNewObject(), 'REAL')

    !json.net.Parse('0.123')
    !assert.instanceOf(!json.CreateNewObject(), 'REAL')

    !json.net.Parse('"foo"')
    !assert.instanceOf(!json.CreateNewObject(), 'STRING')

    !json.net.Parse('null')
    !assert.instanceOf(!json.CreateNewObject(), 'STRING')
endmethod

define method .testGetObjectMemberNames(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()

    -- Object defined from a file
    !expected[1] = 'xLength'
    !expected[2] = 'yLength'
    !expected[3] = 'zLength'
    !expected[4] = 'position'
    !expected[5] = 'orientation'
    !assert.equal(!expected, !json.GetObjectMemberNames(object GMFBOX()))
    !expected.Delete()

    -- PML native object
    !expected[1] = 'EAST'
    !expected[2] = 'NORTH'
    !expected[3] = 'ORIGIN'
    !expected[4] = 'UP'
    !assert.equal(!expected, !json.GetObjectMemberNames(object POSITION()))
    !expected.Delete()

    -- Object with no member
    !expected = object ARRAY()
    !assert.equal(!expected, !json.GetObjectMemberNames(object BLOCK()))
endmethod

define method .testParseString(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !actual = object STRING()
    !json.Parse('"foo bar baz"', !actual)
    !assert.equal('foo bar baz', !actual)
endmethod

define method .testParseStringWithBackslashes(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !actual = object STRING()
    !json.Parse('"foo\\bar\\baz"', !actual)
    !assert.equal('foo\bar\baz', !actual)
endmethod

define method .testParseStringWithQuotes(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !actual = object STRING()
    !json.Parse('"foo \"bar\" baz"', !actual)
    !assert.equal('foo "bar" baz', !actual)
endmethod

define method .testParseStringWithTabs(!assert is PmlAssert)
