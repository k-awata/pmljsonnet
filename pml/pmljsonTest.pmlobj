define method .testStringifyObject(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !box = object GMFBOX()
    !box.xLength = 123
    !box.yLength = 456
    !box.zLength = 789
    !box.position = object POSITION('E 123 N 456 U 789')
    !box.orientation = object ORIENTATION('Y is W and Z is U')
    !json = object PMLJSON()
    !assert.equal('{"xLength":123,"yLength":456,"zLength":789,"position":{"EAST":"123mm","NORTH":"456mm","ORIGIN":"/*","UP":"789mm"},"orientation":{"ALPHA":0,"BETA":0,"GAMMA":90,"ORIGIN":"/*"}}', !json.Stringify(!box))
endmethod

define method .testStringifyObjectWithNoMembers(!assert is PmlAssert)
    using namespace 'PMLJsonNet'
    !json = object PMLJSON()
    !assert.equal('"100mm"', !json.Stringify(object BORE('100mm')))
endmethod

define method .testStringifyObjectNullWithNoMembers(!assert is PmlAssert)
